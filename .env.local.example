# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Your org ID (from the organizations table)
ORGANIZATION_ID=your-org-uuid-here

# Google Maps (for Places autocomplete in formulier)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...

# Supabase Edge Function URL for SUUS chat
# After deploying: supabase functions deploy suus
SUPABASE_SUUS_EDGE_URL=https://xxxx.supabase.co/functions/v1/suus

# The main app URL (for "Contact bekijken" link in formulier)
NEXT_PUBLIC_APP_URL=https://your-main-app.vercel.app

# OpenAI (used in edge function, set in Supabase dashboard)
# OPENAI_API_KEY=sk-...  ← set via: supabase secrets set OPENAI_API_KEY=sk-...
