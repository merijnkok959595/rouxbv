# Supabase (nieuw project: zie supabase/README.md + migrations/00001_roux_schema.sql)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# UUID uit: select id from organizations;  (na schema-run)
ORGANIZATION_ID=

# Google Maps (for Places autocomplete in formulier)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...

# Supabase Edge Function URL for SUUS chat
# After deploying: supabase functions deploy suus
SUPABASE_SUUS_EDGE_URL=https://xxxx.supabase.co/functions/v1/suus

# The main app URL (for "Contact bekijken" link in formulier)
NEXT_PUBLIC_APP_URL=https://your-main-app.vercel.app

# OpenAI (used in edge function, set in Supabase dashboard)
# OPENAI_API_KEY=sk-...  ← set via: supabase secrets set OPENAI_API_KEY=sk-...

# Retell AI — voice calls (https://retell.ai → API Keys)
RETELL_API_KEY=key_...
RETELL_AGENT_ID=agent_...            # WhatsApp/web agent
RETELL_VOICE_AGENT_ID=agent_...      # Inbound voice agent (Twilio → Retell SIP)

# Twilio — WhatsApp + voice
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_FROM=whatsapp:+31...

# GoHighLevel (server-side only, never NEXT_PUBLIC_)
GHL_API_KEY=pit-your-private-integration-token
GHL_LOCATION_ID=your-location-id
